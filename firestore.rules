rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required) - Project ID
    //   - title: string (required) - Project Title
    //   - data: string (required) - JSON stringified project data
    //   - updatedAt: string (required, ISO 8601) - Last update time
    //   - userId: string (required) - Owner's UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'data', 'updatedAt', 'userId']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.data is string && data.data.size() < 1048576 && // Max 1MB
             data.updatedAt is string &&
             data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      
      match /projects/{projectId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProject(request.resource.data);
        allow update: if isOwner(userId) && isValidProject(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
